class Carro(Vehiculo):  # herencia
    def __init__(self, marca, color, velocidad, puertas):
        super().__init__(marca, color, velocidad)
        self.puertas = puertas

    def mostrar_puertas(self):
        print("Puertas:", self.puertas)


# Objeto CARRO
carro = Carro("Toyota", "Azul", 180, 4)
carro.acelerar()
carro.mostrar_puertas()
print("Velocidad:", carro.get_velocidad())
