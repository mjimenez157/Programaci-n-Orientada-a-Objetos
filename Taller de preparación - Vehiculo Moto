class Vehiculo:
    def __init__(self, marca, color, velocidad):
        self.marca = marca
        self.color = color
        self.__velocidad = velocidad

    def acelerar(self):
        print("El vehículo está acelerando")

    def get_velocidad(self):
        return self.__velocidad


# Objeto MOTO
moto = Vehiculo("Yamaha", "Rojo", 120)
moto.acelerar()
print("Velocidad:", moto.get_velocidad())
