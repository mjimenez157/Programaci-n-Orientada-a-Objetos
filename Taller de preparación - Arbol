class Arbol:
    def __init__(self, tipo, altura, edad):
        self.tipo = tipo
        self.altura = altura
        self.__edad = edad

    def crecer(self):
        print("El árbol está creciendo")

    def get_edad(self):
        return self.__edad


# Objeto PINO
pino = Arbol("Pino", 5, 10)
pino.crecer()
print("Edad:", pino.get_edad())
